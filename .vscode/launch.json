    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug D project (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/my_next_d_project",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "dub: build",
            "console": "integratedTerminal",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug D project (Linux, Stop at entry)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/my_next_d_project",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "dub: build",
            "console": "integratedTerminal",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
